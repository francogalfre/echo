{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 92,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",

  "sortPackageJson": true,
  "insertFinalNewline": true,
  "ignorePatterns": [
    "**/.agents/**",
    "**/dist/**",
    "**/.expo/**",
    "**/.turbo/**",
    "**/src/migrations/**",
    "bun.lock"
  ]
}
