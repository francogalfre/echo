{
  "name": "echo",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "hono": "^4.8.2",
      "@trpc/server": "^11.16.0",
      "better-auth": "1.6.11",
      "next-themes": "^0.4.6",
      "react": "^19.2.6",
      "react-dom": "^19.2.6",
      "sonner": "^2.0.5",
      "@trpc/client": "^11.16.0",
      "@polar-sh/better-auth": "^1.8.4",
      "@types/react": "^19.2.15",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check:types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @echo/db db:push",
    "db:studio": "turbo -F @echo/db db:studio",
    "db:generate": "turbo -F @echo/db db:generate",
    "db:migrate": "turbo -F @echo/db db:migrate",
    "lint": "oxlint",
    "format": "oxfmt --write",
    "check": "oxlint && oxfmt --write",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@echo/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@echo/config": "workspace:*",
    "@types/bun": "catalog:",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "turbo": "^2.9.16",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.2.17"
}
